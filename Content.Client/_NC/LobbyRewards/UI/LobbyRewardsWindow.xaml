<controls:FancyWindow xmlns="https://spacestation14.io"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
        xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
        Title="НАГРАДЫ"
        SetSize="1100 700"
        MinWidth="1000" MinHeight="650">

    <LayoutContainer Name="MainLayout">
        <!-- LAYER 0: DARK BACKGROUND -->
        <PanelContainer LayoutContainer.AnchorRight="1" LayoutContainer.AnchorBottom="1">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#0D1117"/>
            </PanelContainer.PanelOverride>
        </PanelContainer>

        <!-- LAYER 1: MAIN CONTENT -->
        <BoxContainer Orientation="Vertical" Margin="8"
                      LayoutContainer.AnchorRight="1" LayoutContainer.AnchorBottom="1">

            <!-- ═══ TOP HEADER BAR ═══ -->
            <PanelContainer HorizontalExpand="True" MinHeight="40">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#161B22"
                                      BorderColor="#00FF9D" BorderThickness="0 0 0 2"/>
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" Margin="12 6" HorizontalExpand="True">
                    <!-- Tab buttons -->
                    <Button Name="StorageTabButton" Text="СКЛАД" MinWidth="160"
                            StyleClasses="OpenLeft"/>
                    <Button Name="MarketTabButton" Text="МАГАЗИН НАГРАД" MinWidth="160"
                            StyleClasses="OpenRight"/>
                    <Control HorizontalExpand="True"/>
                </BoxContainer>
            </PanelContainer>

            <!-- ═══ CONTENT AREA ═══ -->
            <!-- Storage/Loadout Panel (shown when StorageTab is active) -->
            <BoxContainer Name="StoragePanel" Orientation="Horizontal" VerticalExpand="True"
                          SeparationOverride="4" Margin="0 4 0 0">

                <!-- LEFT: Category sidebar -->
                <PanelContainer MinWidth="130">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#0D1117"
                                          BorderColor="#30363D" BorderThickness="0 0 1 0"/>
                    </PanelContainer.PanelOverride>
                    <BoxContainer Name="CategoryButtons" Orientation="Vertical" Margin="4"
                                  SeparationOverride="4"/>
                </PanelContainer>

                <!-- CENTER: Item grid + header -->
                <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                    <!-- Storage header -->
                    <PanelContainer MinHeight="36">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#161B22"/>
                        </PanelContainer.PanelOverride>
                        <BoxContainer Orientation="Horizontal" Margin="10 4" HorizontalExpand="True">
                            <Label Text="СКЛАД / СБОРКА РАУНДА" StyleClasses="LabelHeading"
                                   FontColorOverride="#C9D1D9"/>
                        </BoxContainer>
                    </PanelContainer>

                    <!-- Items grid (scrollable) -->
                    <PanelContainer VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#0D1117"
                                              BorderColor="#30363D" BorderThickness="1"/>
                        </PanelContainer.PanelOverride>
                        <ScrollContainer VerticalExpand="True" HorizontalExpand="True" Margin="4">
                            <GridContainer Name="InventoryGrid" Columns="3" HorizontalExpand="True"
                                           HSeparationOverride="8" VSeparationOverride="8" Margin="4"/>
                        </ScrollContainer>
                    </PanelContainer>

                    <!-- Bottom action bar -->
                    <BoxContainer Orientation="Horizontal" SeparationOverride="8" Margin="0 4 0 0">
                        <Button Name="ResetLoadoutButton" Text="СБРОСИТЬ СБОРКУ"
                                StyleClasses="ButtonColorRed" HorizontalExpand="True" MinHeight="32"/>
                        <Button Name="SaveLoadoutButton" Text="СОХРАНИТЬ СБОРКУ"
                                StyleClasses="ButtonColorGreen" HorizontalExpand="True" MinHeight="32"/>
                    </BoxContainer>
                </BoxContainer>

                <!-- RIGHT: Loadout sidebar ("МОЯ СБОРКА") -->
                <PanelContainer MinWidth="200" MaxWidth="220">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#161B22"
                                          BorderColor="#30363D" BorderThickness="1"/>
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="4">
                        <Label Text="МОЯ СБОРКА" StyleClasses="LabelHeading"
                               FontColorOverride="#00FF9D" HorizontalAlignment="Center"/>
                        <PanelContainer MinHeight="2">
                            <PanelContainer.PanelOverride>
                                <gfx:StyleBoxFlat BackgroundColor="#30363D"/>
                            </PanelContainer.PanelOverride>
                        </PanelContainer>
                        <ScrollContainer VerticalExpand="True">
                            <BoxContainer Name="LoadoutList" Orientation="Vertical"
                                          SeparationOverride="4"/>
                        </ScrollContainer>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>

            <!-- Market Panel (hidden by default, shown when MarketTab is active) -->
            <BoxContainer Name="MarketPanel" Orientation="Vertical" VerticalExpand="True"
                          Visible="False" Margin="0 4 0 0" SeparationOverride="4">

                <!-- Market header -->
                <PanelContainer MinHeight="36">
                    <PanelContainer.PanelOverride>
                        <gfx:StyleBoxFlat BackgroundColor="#161B22"/>
                    </PanelContainer.PanelOverride>
                    <BoxContainer Orientation="Horizontal" Margin="10 4" HorizontalExpand="True">
                        <Label Text="МАГАЗИН" StyleClasses="LabelHeading"
                               FontColorOverride="#C9D1D9"/>
                        <Control HorizontalExpand="True"/>
                        <Label Text="ТЕКУЩИЙ БАЛАНС:" StyleClasses="LabelSubtext"
                               FontColorOverride="#8B949E" VerticalAlignment="Center"/>
                        <Label Name="MarketBalanceLabel" Text=" 0 NC" StyleClasses="LabelHeading"
                               FontColorOverride="#00FFFF" Margin="4 0 0 0"/>
                    </BoxContainer>
                </PanelContainer>

                <!-- Market content: grid + description panel -->
                <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="4">
                    <!-- Market grid -->
                    <PanelContainer HorizontalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#0D1117"
                                              BorderColor="#30363D" BorderThickness="1"/>
                        </PanelContainer.PanelOverride>
                        <ScrollContainer VerticalExpand="True" HorizontalExpand="True" Margin="4">
                            <GridContainer Name="MarketGrid" Columns="4" HorizontalExpand="True"
                                           HSeparationOverride="8" VSeparationOverride="8" Margin="4"/>
                        </ScrollContainer>
                    </PanelContainer>

                    <!-- Description / preview panel -->
                    <PanelContainer MinWidth="250" MaxWidth="280">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#161B22"
                                              BorderColor="#30363D" BorderThickness="1"/>
                        </PanelContainer.PanelOverride>
                        <BoxContainer Name="DescriptionPanel" Orientation="Vertical" Margin="10"
                                      SeparationOverride="8">
                            <Label Text="ДЕСКРИПТОН:" StyleClasses="LabelHeading"
                                   FontColorOverride="#8B949E"/>
                            <PanelContainer MinHeight="2">
                                <PanelContainer.PanelOverride>
                                    <gfx:StyleBoxFlat BackgroundColor="#30363D"/>
                                </PanelContainer.PanelOverride>
                            </PanelContainer>
                            <BoxContainer Name="PreviewContent" Orientation="Vertical"
                                          SeparationOverride="6" VerticalExpand="True"
                                          HorizontalExpand="True"/>
                        </BoxContainer>
                    </PanelContainer>
                </BoxContainer>
            </BoxContainer>

        </BoxContainer>
    </LayoutContainer>
</controls:FancyWindow>
